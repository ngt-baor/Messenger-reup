{
  "name": "messenger",
  "version": "1.3.0",
  "description": "Ứng dụng Messenger Desktop cho Windows - Chạy trên nhân Chrome (Chromium)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.messenger.desktop",
    "productName": "Messenger",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/afterPack.js",
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "shortcutName": "Messenger",
      "artifactName": "Messenger-Setup-${version}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "custom_style.css",
      "icon.ico",
      "icon.png",
      "package.json"
    ],
    "publish": []
  },
  "keywords": [
    "messenger",
    "facebook",
    "desktop",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}

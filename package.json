{
  "name": "messenger",
  "version": "1.2.1",
  "description": "Messenger + Discord multi-account desktop for Windows (Electron/Chromium)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "npm run test:privacy && npm run test:service && npm run test:settings-update",
    "test:privacy": "node scripts/testPrivacy.js",
    "test:privacy:cdp": "electron scripts/testPrivacyCdp.js",
    "test:service": "node scripts/testServiceModel.js",
    "test:settings-update": "node scripts/testSettingsUpdateAction.js",
    "test:update-ui": "electron scripts/testUpdateProgressUi.js",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "pack": "node scripts/release-build.js",
    "pack:portable": "node scripts/release-build.js --portable",
    "pack:clean": "node scripts/release-build.js --clean",
    "release": "node scripts/release-build.js --publish",
    "release:raw": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.messenger.desktop",
    "productName": "Messenger",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/afterPack.js",
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "include": "build/installer.nsh",
      "shortcutName": "Messenger",
      "artifactName": "MessengerSetup-${version}.${ext}"
    },
    "files": [
      "main.js",
      "privacy.js",
      "service-model.js",
      "preload.js",
      "settings-preload.js",
      "renderer.js",
      "settings-renderer.js",
      "index.html",
      "settings.html",
      "settings.css",
      "custom_style.css",
      "icon.ico",
      "icon.png",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Baor-05",
        "repo": "Messenger-reup"
      }
    ]
  },
  "keywords": [
    "messenger",
    "facebook",
    "desktop",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
